<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.backend.mapper.SpeciesMapper">

    <resultMap id="SpeciesResultMap" type="com.backend.entity.SpeciesEntity">
        <id column="species_id" property="speciesId" />
        <result column="japanese_name" property="japaneseName" />
        <result column="common_name" property="commonName" />
        <result column="english_name" property="englishName" />
        <result column="total_length" property="totalLength" />
        <result column="body_weight" property="bodyWeight" />
        <result column="lifespan" property="lifespan" />
    </resultMap>

    <select id="findAll" resultMap="SpeciesResultMap">
        SELECT
            species_id,
            japanese_name,
            common_name,
            english_name,
            total_length,
            body_weight,
            lifespan
        FROM
            species
        ORDER BY
            species_id
    </select>

</mapper>
